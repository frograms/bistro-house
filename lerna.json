{
  "$schema": "node_modules/@lerna-lite/cli/schemas/lerna-schema.json",
  "version": "independent",
  "npmClient": "pnpm",
  "describeTag": "*@*",
  "packages": ["packages/*"],
  "command": {
    "publish": {
      "conventionalCommits": true,
      "changelogPreset": "angular",
      "message": "chore(release): publish packages [skip ci]"
    }
  }
}
