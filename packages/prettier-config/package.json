{
  "name": "@watcha-authentic/prettier-config",
  "description": "watcha common prettier package",
  "keywords": ["prettier", "config"],
  "version": "0.1.0",
  "homepage": "https://github.com/frograms/bistro-house/tree/master/packages/prettier-config#readme",
  "author": {
    "name": "@watcha-authentic#web-dev-group",
    "email": "web-dev-group@watcha.com",
    "url": "https://github.com/frograms"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frograms/bistro-house"
  },
  "bugs": {
    "url": "https://github.com/frograms/bistro-house/issues",
    "email": "web-dev-group@watcha.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "echo Test skipped...",
    "validate": "tsc && npm run lint && npm run build",
    "lint": "eslint .",
    "build:cjs": "swc src --out-dir ./dist/cjs --config-file swc-cjs.json --ignore '**/*.d.ts' --strip-leading-paths",
    "build:esm": "swc src --out-dir ./dist/esm --config-file swc-esm.json --ignore '**/*.d.ts' --strip-leading-paths",
    "build:type": "tsc --outDir ./dist/type --project ./tsconfig.type.json",
    "build": "rm -rf ./dist && concurrently -n CJS,ESM,TYPE 'pnpm build:cjs' 'pnpm build:esm' 'pnpm build:type' && pnpm post-build",
    "post-build": "bash ./project-attachment/post-build.sh"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/type/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/type/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.7",
    "chokidar": "^4.0.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.7.4"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "license": "MIT"
}
